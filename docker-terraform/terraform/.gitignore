# Local .terraform directories (contains plugins, modules, and providers)
**/.terraform/*

# .tfstate files (contains plain-text secrets and state information)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all variable files by default (contain credentials and secrets)
*.tfvars
*.tfvars.json

# Exclude local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include a specific override file if strictly required by your project
# !example_override.tf

# Ignore CLI configuration files
.terraformrc
terraform.rc
docker-terraform/terraform/keys/service_account_key.json